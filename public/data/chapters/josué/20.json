{
  "title": "Josué 20",
  "book_name": "Josué",
  "book_slug": "josué",
  "chapter_number": 20,
  "introduction": "<p class=\"wp-block-paragraph\"><a href=\"https://www.die-bibel.de/en/bible/BHS/JOS.20\" rel=\"noreferrer noopener\" target=\"_blank\">Josué 20 na <em>Biblia Hebraica Stuttgartensia</em></a></p>\n<p class=\"wp-block-paragraph\"><a href=\"https://www.youtube.com/watch?v=q5-I3uhbSG8\" rel=\"noreferrer noopener\" target=\"_blank\">Comentário a Josué 20,1-3</a></p>\n<p class=\"wp-block-paragraph\"><a href=\"https://www.youtube.com/watch?v=dgndF1j9R74\" rel=\"noreferrer noopener\" target=\"_blank\">Comentário a Josué 20,4-6</a></p>\n<p class=\"wp-block-paragraph\"><a href=\"https://www.youtube.com/watch?v=g4bENTl7TW0\" rel=\"noreferrer noopener\" target=\"_blank\">Comentário a Josué 20,7-9</a></p>",
  "verses": [
    {
      "number": 1,
      "text": "E fala Yahweh. A Yeshosua’. Para dizer.",
      "lines": [
        {
          "line_index": 0,
          "text": "E fala Yahweh.",
          "raw_html": "<p class=\"wp-block-paragraph\">E fala Yahweh.</p>"
        },
        {
          "line_index": 1,
          "text": "A Yeshosua’.",
          "raw_html": "<p class=\"wp-block-paragraph\">A Yeshosua’<a name=\"rf1-18816\"></a><sup><a href=\"#fn1-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 1\">1</a></sup>.</p>"
        },
        {
          "line_index": 2,
          "text": "Para dizer.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para dizer<a name=\"rf2-18816\"></a><sup><a href=\"#fn2-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 2\">2</a></sup>.</p>"
        }
      ]
    },
    {
      "number": 2,
      "text": "Fala tu. Aos filhos de Yisra’el. Para dizer. Dai. Para vós. As cidades do refúgio. Que falei eu. A vós. Na mão de Mosheh.",
      "lines": [
        {
          "line_index": 0,
          "text": "Fala tu.",
          "raw_html": "<p class=\"wp-block-paragraph\"> Fala tu.</p>"
        },
        {
          "line_index": 1,
          "text": "Aos filhos de Yisra’el.",
          "raw_html": "<p class=\"wp-block-paragraph\">Aos filhos de Yisra’el<a name=\"rf3-18816\"></a><sup><a href=\"#fn3-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 3\">3</a></sup>.</p>"
        },
        {
          "line_index": 2,
          "text": "Para dizer.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para dizer<a name=\"rf4-18816\"></a><sup><a href=\"#fn4-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 4\">4</a></sup>.</p>"
        },
        {
          "line_index": 3,
          "text": "Dai.",
          "raw_html": "<p class=\"wp-block-paragraph\">Dai.</p>"
        },
        {
          "line_index": 4,
          "text": "Para vós.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para vós.</p>"
        },
        {
          "line_index": 5,
          "text": "As cidades do refúgio.",
          "raw_html": "<p class=\"wp-block-paragraph\">As cidades do refúgio.</p>"
        },
        {
          "line_index": 6,
          "text": "Que falei eu.",
          "raw_html": "<p class=\"wp-block-paragraph\">Que falei eu.</p>"
        },
        {
          "line_index": 7,
          "text": "A vós.",
          "raw_html": "<p class=\"wp-block-paragraph\">A vós<a name=\"rf5-18816\"></a><sup><a href=\"#fn5-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 5\">5</a></sup>.</p>"
        },
        {
          "line_index": 8,
          "text": "Na mão de Mosheh.",
          "raw_html": "<p class=\"wp-block-paragraph\">Na mão de<a name=\"rf6-18816\"></a><sup><a href=\"#fn6-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 6\">6</a></sup> Mosheh<a name=\"rf7-18816\"></a><sup><a href=\"#fn7-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 7\">7</a></sup>.</p>"
        }
      ]
    },
    {
      "number": 3,
      "text": "Para fugir. Para lá. Assassinador. Fazedor de ferir garganta. Em ignorância. Em não conhecimento. E está. Para vós. Para refúgio. Desde o resgatador de sangue.",
      "lines": [
        {
          "line_index": 0,
          "text": "Para fugir.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para fugir<a name=\"rf8-18816\"></a><sup><a href=\"#fn8-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 8\">8</a></sup><a name=\"rf9-18816\"></a><sup><a href=\"#fn9-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 9\">9</a></sup>.</p>"
        },
        {
          "line_index": 1,
          "text": "Para lá.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para lá<a name=\"rf10-18816\"></a><sup><a href=\"#fn10-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 10\">10</a></sup>.</p>"
        },
        {
          "line_index": 2,
          "text": "Assassinador.",
          "raw_html": "<p class=\"wp-block-paragraph\">Assassinador.</p>"
        },
        {
          "line_index": 3,
          "text": "Fazedor de ferir garganta.",
          "raw_html": "<p class=\"wp-block-paragraph\">Fazedor de ferir garganta.</p>"
        },
        {
          "line_index": 4,
          "text": "Em ignorância.",
          "raw_html": "<p class=\"wp-block-paragraph\">Em ignorância.</p>"
        },
        {
          "line_index": 5,
          "text": "Em não conhecimento.",
          "raw_html": "<p class=\"wp-block-paragraph\">Em não conhecimento.</p>"
        },
        {
          "line_index": 6,
          "text": "E está.",
          "raw_html": "<p class=\"wp-block-paragraph\">E está<a name=\"rf11-18816\"></a><sup><a href=\"#fn11-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 11\">11</a></sup>.</p>"
        },
        {
          "line_index": 7,
          "text": "Para vós.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para vós.</p>"
        },
        {
          "line_index": 8,
          "text": "Para refúgio.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para refúgio.</p>"
        },
        {
          "line_index": 9,
          "text": "Desde o resgatador de sangue.",
          "raw_html": "<p class=\"wp-block-paragraph\">Desde o resgatador de sangue.</p>"
        }
      ]
    },
    {
      "number": 4,
      "text": "E foge ele. A uma das cidades essas. E acoluna ele. Abrimento do portão da cidade. E fala ele. Nas orelhas dos velhos da cidade aquela. Os falados dele. E reúnem eles. Ele. Para a cidade. A eles. E dão eles. Para ele. Lugar. E assenta ele. Com eles.",
      "lines": [
        {
          "line_index": 0,
          "text": "E foge ele.",
          "raw_html": "<p class=\"wp-block-paragraph\"> E foge ele<a name=\"rf12-18816\"></a><sup><a href=\"#fn12-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 12\">12</a></sup>.</p>"
        },
        {
          "line_index": 1,
          "text": "A uma das cidades essas.",
          "raw_html": "<p class=\"wp-block-paragraph\">A uma das cidades essas.</p>"
        },
        {
          "line_index": 2,
          "text": "E acoluna ele.",
          "raw_html": "<p class=\"wp-block-paragraph\">E acoluna ele<a name=\"rf13-18816\"></a><sup><a href=\"#fn13-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 13\">13</a></sup><a name=\"rf14-18816\"></a><sup><a href=\"#fn14-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 14\">14</a></sup>.</p>"
        },
        {
          "line_index": 3,
          "text": "Abrimento do portão da cidade.",
          "raw_html": "<p class=\"wp-block-paragraph\">Abrimento do portão da cidade.</p>"
        },
        {
          "line_index": 4,
          "text": "E fala ele.",
          "raw_html": "<p class=\"wp-block-paragraph\">E fala ele.</p>"
        },
        {
          "line_index": 5,
          "text": "Nas orelhas dos velhos da cidade aquela.",
          "raw_html": "<p class=\"wp-block-paragraph\">Nas orelhas dos velhos da<a name=\"rf15-18816\"></a><sup><a href=\"#fn15-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 15\">15</a></sup> cidade aquela.</p>"
        },
        {
          "line_index": 6,
          "text": "Os falados dele.",
          "raw_html": "<p class=\"wp-block-paragraph\">Os falados dele.</p>"
        },
        {
          "line_index": 7,
          "text": "E reúnem eles.",
          "raw_html": "<p class=\"wp-block-paragraph\">E reúnem eles<a name=\"rf16-18816\"></a><sup><a href=\"#fn16-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 16\">16</a></sup>.</p>"
        },
        {
          "line_index": 8,
          "text": "Ele.",
          "raw_html": "<p class=\"wp-block-paragraph\">Ele.</p>"
        },
        {
          "line_index": 9,
          "text": "Para a cidade.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para a cidade<a name=\"rf17-18816\"></a><sup><a href=\"#fn17-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 17\">17</a></sup>.</p>"
        },
        {
          "line_index": 10,
          "text": "A eles.",
          "raw_html": "<p class=\"wp-block-paragraph\">A eles<a name=\"rf18-18816\"></a><sup><a href=\"#fn18-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 18\">18</a></sup>.</p>"
        },
        {
          "line_index": 11,
          "text": "E dão eles.",
          "raw_html": "<p class=\"wp-block-paragraph\">E dão eles.</p>"
        },
        {
          "line_index": 12,
          "text": "Para ele.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para ele.</p>"
        },
        {
          "line_index": 13,
          "text": "Lugar.",
          "raw_html": "<p class=\"wp-block-paragraph\">Lugar.</p>"
        },
        {
          "line_index": 14,
          "text": "E assenta ele.",
          "raw_html": "<p class=\"wp-block-paragraph\">E assenta ele.</p>"
        },
        {
          "line_index": 15,
          "text": "Com eles.",
          "raw_html": "<p class=\"wp-block-paragraph\">Com eles.</p>"
        }
      ]
    },
    {
      "number": 5,
      "text": "E que persegue. O resgatador do sangue. Depois dele. E não fazem eles fechar. O assassinador. Na mão dele. Que em não conhecimento. Faz ele ferir o companheiro dele. E não odiador ele para ele. Desde ontem tresontonte.",
      "lines": [
        {
          "line_index": 0,
          "text": "E que persegue.",
          "raw_html": "<p class=\"wp-block-paragraph\"> E que persegue<a name=\"rf19-18816\"></a><sup><a href=\"#fn19-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 19\">19</a></sup>.</p>"
        },
        {
          "line_index": 1,
          "text": "O resgatador do sangue.",
          "raw_html": "<p class=\"wp-block-paragraph\">O resgatador do sangue.</p>"
        },
        {
          "line_index": 2,
          "text": "Depois dele.",
          "raw_html": "<p class=\"wp-block-paragraph\">Depois<a name=\"rf20-18816\"></a><sup><a href=\"#fn20-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 20\">20</a></sup> dele<a name=\"rf21-18816\"></a><sup><a href=\"#fn21-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 21\">21</a></sup>.</p>"
        },
        {
          "line_index": 3,
          "text": "E não fazem eles fechar.",
          "raw_html": "<p class=\"wp-block-paragraph\">E não fazem eles fechar<a name=\"rf22-18816\"></a><sup><a href=\"#fn22-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 22\">22</a></sup>.</p>"
        },
        {
          "line_index": 4,
          "text": "O assassinador.",
          "raw_html": "<p class=\"wp-block-paragraph\">O assassinador.</p>"
        },
        {
          "line_index": 5,
          "text": "Na mão dele.",
          "raw_html": "<p class=\"wp-block-paragraph\">Na mão dele<a name=\"rf23-18816\"></a><sup><a href=\"#fn23-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 23\">23</a></sup>.</p>"
        },
        {
          "line_index": 6,
          "text": "Que em não conhecimento.",
          "raw_html": "<p class=\"wp-block-paragraph\">Que em não conhecimento.</p>"
        },
        {
          "line_index": 7,
          "text": "Faz ele ferir o companheiro dele.",
          "raw_html": "<p class=\"wp-block-paragraph\">Faz ele ferir o companheiro dele.</p>"
        },
        {
          "line_index": 8,
          "text": "E não odiador ele para ele.",
          "raw_html": "<p class=\"wp-block-paragraph\">E não odiador ele para ele.</p>"
        },
        {
          "line_index": 9,
          "text": "Desde ontem tresontonte.",
          "raw_html": "<p class=\"wp-block-paragraph\">Desde ontem tresontonte.</p>"
        }
      ]
    },
    {
      "number": 6,
      "text": "E assenta ele. Na cidade aquela. Até o acolunar dele. Para as faces da congregação. Para o julgamento. Até a morte do sacerdote grande. Que está. Nos dias. Os eles. Então. Volta o assassinador. E vai ele. À cidade dele. E ao lar dele. À cidade. Que foge ele. Desde lá.",
      "lines": [
        {
          "line_index": 0,
          "text": "E assenta ele.",
          "raw_html": "<p class=\"wp-block-paragraph\">E assenta ele.</p>"
        },
        {
          "line_index": 1,
          "text": "Na cidade aquela.",
          "raw_html": "<p class=\"wp-block-paragraph\">Na cidade aquela.</p>"
        },
        {
          "line_index": 2,
          "text": "Até o acolunar dele.",
          "raw_html": "<p class=\"wp-block-paragraph\">Até o acolunar<a name=\"rf24-18816\"></a><sup><a href=\"#fn24-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 24\">24</a></sup> dele.</p>"
        },
        {
          "line_index": 3,
          "text": "Para as faces da congregação.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para as faces da<a name=\"rf25-18816\"></a><sup><a href=\"#fn25-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 25\">25</a></sup> congregação.</p>"
        },
        {
          "line_index": 4,
          "text": "Para o julgamento.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para o julgamento.</p>"
        },
        {
          "line_index": 5,
          "text": "Até a morte do sacerdote grande.",
          "raw_html": "<p class=\"wp-block-paragraph\">Até a morte do sacerdote grande.</p>"
        },
        {
          "line_index": 6,
          "text": "Que está.",
          "raw_html": "<p class=\"wp-block-paragraph\">Que está<a name=\"rf26-18816\"></a><sup><a href=\"#fn26-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 26\">26</a></sup>.</p>"
        },
        {
          "line_index": 7,
          "text": "Nos dias.",
          "raw_html": "<p class=\"wp-block-paragraph\">Nos dias.</p>"
        },
        {
          "line_index": 8,
          "text": "Os eles.",
          "raw_html": "<p class=\"wp-block-paragraph\">Os eles<a name=\"rf27-18816\"></a><sup><a href=\"#fn27-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 27\">27</a></sup>.</p>"
        },
        {
          "line_index": 9,
          "text": "Então.",
          "raw_html": "<p class=\"wp-block-paragraph\">Então<a name=\"rf28-18816\"></a><sup><a href=\"#fn28-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 28\">28</a></sup>.</p>"
        },
        {
          "line_index": 10,
          "text": "Volta o assassinador.",
          "raw_html": "<p class=\"wp-block-paragraph\">Volta<a name=\"rf29-18816\"></a><sup><a href=\"#fn29-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 29\">29</a></sup> o assassinador.</p>"
        },
        {
          "line_index": 11,
          "text": "E vai ele.",
          "raw_html": "<p class=\"wp-block-paragraph\">E vai ele<a name=\"rf30-18816\"></a><sup><a href=\"#fn30-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 30\">30</a></sup>.</p>"
        },
        {
          "line_index": 12,
          "text": "À cidade dele.",
          "raw_html": "<p class=\"wp-block-paragraph\">À cidade dele.</p>"
        },
        {
          "line_index": 13,
          "text": "E ao lar dele.",
          "raw_html": "<p class=\"wp-block-paragraph\">E ao lar<a name=\"rf31-18816\"></a><sup><a href=\"#fn31-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 31\">31</a></sup> dele.</p>"
        },
        {
          "line_index": 14,
          "text": "À cidade.",
          "raw_html": "<p class=\"wp-block-paragraph\">À cidade.</p>"
        },
        {
          "line_index": 15,
          "text": "Que foge ele.",
          "raw_html": "<p class=\"wp-block-paragraph\">Que foge ele<a name=\"rf32-18816\"></a><sup><a href=\"#fn32-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 32\">32</a></sup>.</p>"
        },
        {
          "line_index": 16,
          "text": "Desde lá.",
          "raw_html": "<p class=\"wp-block-paragraph\">Desde lá<a name=\"rf33-18816\"></a><sup><a href=\"#fn33-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 33\">33</a></sup>.</p>"
        }
      ]
    },
    {
      "number": 7,
      "text": "E fazem eles sacralizar. Qedesh. No monte de Naptali. E Shekem. No monte de ‘Eprayim. E Qiryat ‘Arba’. Ela. Hebron. No monte de Yehudah.",
      "lines": [
        {
          "line_index": 0,
          "text": "E fazem eles sacralizar.",
          "raw_html": "<p class=\"wp-block-paragraph\"> E fazem eles sacralizar<a name=\"rf34-18816\"></a><sup><a href=\"#fn34-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 34\">34</a></sup>.</p>"
        },
        {
          "line_index": 1,
          "text": "Qedesh.",
          "raw_html": "<p class=\"wp-block-paragraph\">Qedesh.</p>"
        },
        {
          "line_index": 2,
          "text": "No monte de Naptali.",
          "raw_html": "<p class=\"wp-block-paragraph\">No monte de Naptali.</p>"
        },
        {
          "line_index": 3,
          "text": "E Shekem.",
          "raw_html": "<p class=\"wp-block-paragraph\">E Shekem.</p>"
        },
        {
          "line_index": 4,
          "text": "No monte de ‘Eprayim.",
          "raw_html": "<p class=\"wp-block-paragraph\">No monte de ‘Eprayim.</p>"
        },
        {
          "line_index": 5,
          "text": "E Qiryat ‘Arba’.",
          "raw_html": "<p class=\"wp-block-paragraph\">E Qiryat ‘Arba’.</p>"
        },
        {
          "line_index": 6,
          "text": "Ela.",
          "raw_html": "<p class=\"wp-block-paragraph\">Ela.</p>"
        },
        {
          "line_index": 7,
          "text": "Hebron.",
          "raw_html": "<p class=\"wp-block-paragraph\">Hebron.</p>"
        },
        {
          "line_index": 8,
          "text": "No monte de Yehudah.",
          "raw_html": "<p class=\"wp-block-paragraph\">No monte de Yehudah.</p>"
        }
      ]
    },
    {
      "number": 8,
      "text": "E desde passadouro. Para Yarden. Yeriho. Para levante. Dão eles Betser. No deserto. No planalto. Desde o galho de Re’uben. E Ra’mot. No Gil’ad. Desde o galho de Gad. E Galon. No Bashan. Desde o galho de Menashsheh.",
      "lines": [
        {
          "line_index": 0,
          "text": "E desde passadouro.",
          "raw_html": "<p class=\"wp-block-paragraph\">E desde passadouro<a name=\"rf35-18816\"></a><sup><a href=\"#fn35-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 35\">35</a></sup>.</p>"
        },
        {
          "line_index": 1,
          "text": "Para Yarden.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para Yarden.</p>"
        },
        {
          "line_index": 2,
          "text": "Yeriho.",
          "raw_html": "<p class=\"wp-block-paragraph\">Yeriho<a name=\"rf36-18816\"></a><sup><a href=\"#fn36-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 36\">36</a></sup>.</p>"
        },
        {
          "line_index": 3,
          "text": "Para levante.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para levante.</p>"
        },
        {
          "line_index": 4,
          "text": "Dão eles Betser.",
          "raw_html": "<p class=\"wp-block-paragraph\">Dão eles<a name=\"rf37-18816\"></a><sup><a href=\"#fn37-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 37\">37</a></sup> Betser.</p>"
        },
        {
          "line_index": 5,
          "text": "No deserto.",
          "raw_html": "<p class=\"wp-block-paragraph\">No deserto<a name=\"rf38-18816\"></a><sup><a href=\"#fn38-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 38\">38</a></sup><a name=\"rf39-18816\"></a><sup><a href=\"#fn39-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 39\">39</a></sup>.</p>"
        },
        {
          "line_index": 6,
          "text": "No planalto.",
          "raw_html": "<p class=\"wp-block-paragraph\">No planalto.</p>"
        },
        {
          "line_index": 7,
          "text": "Desde o galho de Re’uben.",
          "raw_html": "<p class=\"wp-block-paragraph\">Desde o galho de Re’uben.</p>"
        },
        {
          "line_index": 8,
          "text": "E Ra’mot.",
          "raw_html": "<p class=\"wp-block-paragraph\">E Ra’mot.</p>"
        },
        {
          "line_index": 9,
          "text": "No Gil’ad.",
          "raw_html": "<p class=\"wp-block-paragraph\">No Gil’ad.</p>"
        },
        {
          "line_index": 10,
          "text": "Desde o galho de Gad.",
          "raw_html": "<p class=\"wp-block-paragraph\">Desde o galho de Gad.</p>"
        },
        {
          "line_index": 11,
          "text": "E Galon.",
          "raw_html": "<p class=\"wp-block-paragraph\">E Galon.</p>"
        },
        {
          "line_index": 12,
          "text": "No Bashan.",
          "raw_html": "<p class=\"wp-block-paragraph\">No Bashan.</p>"
        },
        {
          "line_index": 13,
          "text": "Desde o galho de Menashsheh.",
          "raw_html": "<p class=\"wp-block-paragraph\">Desde o galho de Menashsheh.</p>"
        }
      ]
    },
    {
      "number": 9,
      "text": "Essas. Estão elas. As cidades periodizadas. Para o total dos filhos de Yisra’el. E para o peregrino peregrinador. No meio deles. Para fugir. Para lá. Total de fazedor de ferir garganta. Em ignorância. E não morre ele. Não mão do resgatador do sangue. Até o acolunar dele. Par as faces da congregação.",
      "lines": [
        {
          "line_index": 0,
          "text": "Essas.",
          "raw_html": "<p class=\"wp-block-paragraph\"> Essas.</p>"
        },
        {
          "line_index": 1,
          "text": "Estão elas.",
          "raw_html": "<p class=\"wp-block-paragraph\">Estão elas<a name=\"rf40-18816\"></a><sup><a href=\"#fn40-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 40\">40</a></sup>.</p>"
        },
        {
          "line_index": 2,
          "text": "As cidades periodizadas.",
          "raw_html": "<p class=\"wp-block-paragraph\">As cidades periodizadas.</p>"
        },
        {
          "line_index": 3,
          "text": "Para o total dos filhos de Yisra’el.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para o total dos filhos de Yisra’el<a name=\"rf41-18816\"></a><sup><a href=\"#fn41-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 41\">41</a></sup>.</p>"
        },
        {
          "line_index": 4,
          "text": "E para o peregrino peregrinador.",
          "raw_html": "<p class=\"wp-block-paragraph\">E para o peregrino peregrinador<a name=\"rf42-18816\"></a><sup><a href=\"#fn42-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 42\">42</a></sup>.</p>"
        },
        {
          "line_index": 5,
          "text": "No meio deles.",
          "raw_html": "<p class=\"wp-block-paragraph\">No meio deles.</p>"
        },
        {
          "line_index": 6,
          "text": "Para fugir.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para fugir<a name=\"rf43-18816\"></a><sup><a href=\"#fn43-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 43\">43</a></sup>.</p>"
        },
        {
          "line_index": 7,
          "text": "Para lá.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para lá<a name=\"rf44-18816\"></a><sup><a href=\"#fn44-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 44\">44</a></sup>.</p>"
        },
        {
          "line_index": 8,
          "text": "Total de fazedor de ferir garganta.",
          "raw_html": "<p class=\"wp-block-paragraph\">Total de fazedor de ferir garganta.</p>"
        },
        {
          "line_index": 9,
          "text": "Em ignorância.",
          "raw_html": "<p class=\"wp-block-paragraph\">Em ignorância.</p>"
        },
        {
          "line_index": 10,
          "text": "E não morre ele.",
          "raw_html": "<p class=\"wp-block-paragraph\">E não morre ele.</p>"
        },
        {
          "line_index": 11,
          "text": "Não mão do resgatador do sangue.",
          "raw_html": "<p class=\"wp-block-paragraph\">Não mão do<a name=\"rf45-18816\"></a><sup><a href=\"#fn45-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 45\">45</a></sup> resgatador do sangue.</p>"
        },
        {
          "line_index": 12,
          "text": "Até o acolunar dele.",
          "raw_html": "<p class=\"wp-block-paragraph\">Até o acolunar<a name=\"rf46-18816\"></a><sup><a href=\"#fn46-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 46\">46</a></sup> dele.</p>"
        },
        {
          "line_index": 13,
          "text": "Par as faces da congregação.",
          "raw_html": "<p class=\"wp-block-paragraph\">Par as faces da<a name=\"rf47-18816\"></a><sup><a href=\"#fn47-18816\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 47\">47</a></sup> congregação.</p>"
        }
      ]
    }
