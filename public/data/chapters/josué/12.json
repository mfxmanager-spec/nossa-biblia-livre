        {
          "line_index": 7,
          "text": "E o dividido do Gil’ad.",
          "raw_html": "<p class=\"wp-block-paragraph\">E o dividido do Gil’ad<a name=\"rf7-18456\"></a><sup><a href=\"#fn7-18456\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 7\">7</a></sup>.</p>"
        },
        {
          "line_index": 8,
          "text": "E até Yaboq.",
          "raw_html": "<p class=\"wp-block-paragraph\">E até Yaboq.</p>"
        },
        {
          "line_index": 9,
          "text": "O varzeado.",
          "raw_html": "<p class=\"wp-block-paragraph\">O varzeado.</p>"
        },
        {
          "line_index": 10,
          "text": "Limite dos filhos de ‘Amon.",
