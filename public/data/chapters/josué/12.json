          "raw_html": "<p class=\"wp-block-paragraph\">No passadouro<a name=\"rf3-18456\"></a><sup><a href=\"#fn3-18456\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 3\">3</a></sup>. do Yarden<a name=\"rf4-18456\"></a><sup><a href=\"#fn4-18456\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 4\">4</a></sup>.</p>"
        },
        {
          "line_index": 5,
          "text": "Desde o levante do sol.",
          "raw_html": "<p class=\"wp-block-paragraph\">Desde o levante do sol.</p>"
        },
        {
          "line_index": 6,
          "text": "Desde o varzeado de ‘Arnon.",
          "raw_html": "<p class=\"wp-block-paragraph\">Desde o varzeado de ‘Arnon.</p>"
        },
        {
          "line_index": 7,
          "text": "Até o monte de Hermon.",
          "raw_html": "<p class=\"wp-block-paragraph\">Até o monte de Hermon.</p>"
