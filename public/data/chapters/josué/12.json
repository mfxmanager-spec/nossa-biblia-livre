          "raw_html": "<p class=\"wp-block-paragraph\"> E a <em>‘arabah</em>.</p>"
        },
        {
          "line_index": 1,
          "text": "Até o mar de Kinerot.",
          "raw_html": "<p class=\"wp-block-paragraph\">Até o mar de Kinerot.</p>"
        },
        {
          "line_index": 2,
          "text": "Desde levante.",
