          "raw_html": "<p class=\"wp-block-paragraph\"> E o limite de ‘Og.</p>"
        },
        {
          "line_index": 1,
          "text": "O rei do Bashan.",
          "raw_html": "<p class=\"wp-block-paragraph\">O rei do Bashan.</p>"
        },
        {
          "line_index": 2,
          "text": "Desde o permanecente dos repa’im.",
          "raw_html": "<p class=\"wp-block-paragraph\">Desde o permanecente dos repa’im.</p>"
        },
        {
          "line_index": 3,
          "text": "O assentador.",
