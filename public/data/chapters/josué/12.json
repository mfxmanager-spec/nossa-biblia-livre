        {
          "line_index": 0,
          "text": "Sihon.",
          "raw_html": "<p class=\"wp-block-paragraph\">Sihon.</p>"
        },
        {
          "line_index": 1,
          "text": "O rei do ‘emori.",
          "raw_html": "<p class=\"wp-block-paragraph\">O rei do ‘emori.</p>"
        },
        {
          "line_index": 2,
          "text": "O assentador em Heshbon.",
