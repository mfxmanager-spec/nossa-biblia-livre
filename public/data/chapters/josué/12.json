        },
        {
          "line_index": 4,
          "text": "Desde ‘Aro’er.",
          "raw_html": "<p class=\"wp-block-paragraph\">Desde ‘Aro’er.</p>"
        },
        {
          "line_index": 5,
          "text": "Que sobre o lábio do varzeado de ‘Arnon.",
          "raw_html": "<p class=\"wp-block-paragraph\">Que sobre o lábio do varzeado de ‘Arnon.</p>"
        },
        {
          "line_index": 6,
          "text": "E o meio do varzeado.",
