{
  "title": "Levítico 12",
  "book_name": "Levítico",
  "book_slug": "levítico",
  "chapter_number": 12,
  "introduction": "<p class=\"wp-block-paragraph\"><a href=\"https://www.youtube.com/watch?v=CtqYfFM7Irc&amp;list=PLzeTEbuIqzqCkVc2SYbzG6GCzNS3SYxap&amp;index=16\" rel=\"noreferrer noopener\" target=\"_blank\">Comentário a Levítico 12,1-8</a></p>",
  "verses": [
    {
      "number": 1,
      "text": "E fala Yahweh a Mosheh. Para dizer.",
      "lines": [
        {
          "line_index": 0,
          "text": "E fala Yahweh a Mosheh.",
          "raw_html": "<p class=\"wp-block-paragraph\"> E fala Yahweh a Mosheh.</p>"
        },
        {
          "line_index": 1,
          "text": "Para dizer.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para dizer<a name=\"rf1-8629\"></a><sup><a href=\"#fn1-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 1\">1</a></sup>.</p>"
        }
      ]
    },
    {
      "number": 2,
      "text": "Fala aos filhos de Yisra’el. Para dizer. Mulher quefaz semente. E pare elamacho. E está ela impurasete de dias. Conforme os dias da menstruaçãodo achacardela está ela impura.",
      "lines": [
        {
          "line_index": 0,
          "text": "Fala aos filhos de Yisra’el.",
          "raw_html": "<p class=\"wp-block-paragraph\"> Fala aos filhos de Yisra’el.</p>"
        },
        {
          "line_index": 1,
          "text": "Para dizer.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para dizer<a name=\"rf2-8629\"></a><sup><a href=\"#fn2-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 2\">2</a></sup>.</p>"
        },
        {
          "line_index": 2,
          "text": "Mulher quefaz semente.",
          "raw_html": "<p class=\"wp-block-paragraph\">Mulher que<a name=\"rf3-8629\"></a><sup><a href=\"#fn3-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 3\">3</a></sup>faz semente<a name=\"rf4-8629\"></a><sup><a href=\"#fn4-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 4\">4</a></sup>.</p>"
        },
        {
          "line_index": 3,
          "text": "E pare elamacho.",
          "raw_html": "<p class=\"wp-block-paragraph\">E pare ela<a name=\"rf5-8629\"></a><sup><a href=\"#fn5-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 5\">5</a></sup>macho<a name=\"rf6-8629\"></a><sup><a href=\"#fn6-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 6\">6</a></sup>.</p>"
        },
        {
          "line_index": 4,
          "text": "E está ela impurasete de dias.",
          "raw_html": "<p class=\"wp-block-paragraph\">E está ela impura<a name=\"rf7-8629\"></a><sup><a href=\"#fn7-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 7\">7</a></sup>sete de dias<a name=\"rf8-8629\"></a><sup><a href=\"#fn8-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 8\">8</a></sup>.</p>"
        },
        {
          "line_index": 5,
          "text": "Conforme os dias da menstruaçãodo achacardela está ela impura.",
          "raw_html": "<p class=\"wp-block-paragraph\">Conforme os dias da menstruação<a name=\"rf9-8629\"></a><sup><a href=\"#fn9-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 9\">9</a></sup>do achacar<a name=\"rf10-8629\"></a><sup><a href=\"#fn10-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 10\">10</a></sup>dela está ela impura<a name=\"rf11-8629\"></a><sup><a href=\"#fn11-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 11\">11</a></sup>.</p>"
        }
      ]
    },
    {
      "number": 3,
      "text": "E no diaoitavo. É circuncidadaa carne do prepúcio dele.",
      "lines": [
        {
          "line_index": 0,
          "text": "E no diaoitavo.",
          "raw_html": "<p class=\"wp-block-paragraph\"> E no dia<a name=\"rf12-8629\"></a><sup><a href=\"#fn12-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 12\">12</a></sup>oitavo<a name=\"rf13-8629\"></a><sup><a href=\"#fn13-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 13\">13</a></sup><a name=\"rf14-8629\"></a><sup><a href=\"#fn14-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 14\">14</a></sup>.</p>"
        },
        {
          "line_index": 1,
          "text": "É circuncidadaa carne do prepúcio dele.",
          "raw_html": "<p class=\"wp-block-paragraph\">É circuncidada<a name=\"rf15-8629\"></a><sup><a href=\"#fn15-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 15\">15</a></sup>a carne do prepúcio dele<a name=\"rf16-8629\"></a><sup><a href=\"#fn16-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 16\">16</a></sup>.</p>"
        }
      ]
    },
    {
      "number": 4,
      "text": "E trintadiae três dediasassentaela nos sanguesda purificação. Em total de sacralidadenão toca ela. E ao sacrárionão vai ela. Atéo encherdos dias da purificaçãodela.",
      "lines": [
        {
          "line_index": 0,
          "text": "E trintadiae três dediasassentaela nos sanguesda purificação.",
          "raw_html": "<p class=\"wp-block-paragraph\"> E trinta<a name=\"rf17-8629\"></a><sup><a href=\"#fn17-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 17\">17</a></sup>dia<a name=\"rf18-8629\"></a><sup><a href=\"#fn18-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 18\">18</a></sup>e três de<a name=\"rf19-8629\"></a><sup><a href=\"#fn19-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 19\">19</a></sup>dias<a name=\"rf20-8629\"></a><sup><a href=\"#fn20-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 20\">20</a></sup>assenta<a name=\"rf21-8629\"></a><sup><a href=\"#fn21-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 21\">21</a></sup>ela nos sangues<a name=\"rf22-8629\"></a><sup><a href=\"#fn22-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 22\">22</a></sup>da purificação<a name=\"rf23-8629\"></a><sup><a href=\"#fn23-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 23\">23</a></sup>.</p>"
        },
        {
          "line_index": 1,
          "text": "Em total de sacralidadenão toca ela.",
          "raw_html": "<p class=\"wp-block-paragraph\">Em total de sacralidade<a name=\"rf24-8629\"></a><sup><a href=\"#fn24-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 24\">24</a></sup>não toca ela<a name=\"rf25-8629\"></a><sup><a href=\"#fn25-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 25\">25</a></sup>.</p>"
        },
        {
          "line_index": 2,
          "text": "E ao sacrárionão vai ela.",
          "raw_html": "<p class=\"wp-block-paragraph\">E ao sacrário<a name=\"rf26-8629\"></a><sup><a href=\"#fn26-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 26\">26</a></sup><a name=\"rf27-8629\"></a><sup><a href=\"#fn27-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 27\">27</a></sup>não vai ela<a name=\"rf28-8629\"></a><sup><a href=\"#fn28-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 28\">28</a></sup>.</p>"
        },
        {
          "line_index": 3,
          "text": "Atéo encherdos dias da purificaçãodela.",
          "raw_html": "<p class=\"wp-block-paragraph\">Até<a name=\"rf29-8629\"></a><sup><a href=\"#fn29-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 29\">29</a></sup>o encher<a name=\"rf30-8629\"></a><sup><a href=\"#fn30-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 30\">30</a></sup>dos dias da<a name=\"rf31-8629\"></a><sup><a href=\"#fn31-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 31\">31</a></sup> purificação<a name=\"rf32-8629\"></a><sup><a href=\"#fn32-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 32\">32</a></sup>dela<a name=\"rf33-8629\"></a><sup><a href=\"#fn33-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 33\">33</a></sup>.</p>"
        }
      ]
    },
    {
      "number": 5,
      "text": "E sefêmeapare ela. E está ela impurasétuplos. Conforme a menstruaçãodela. E sessentadiae seis de diasassentaela sobre os sanguesda purificação.",
      "lines": [
        {
          "line_index": 0,
          "text": "E sefêmeapare ela.",
          "raw_html": "<p class=\"wp-block-paragraph\"> E se<a name=\"rf34-8629\"></a><sup><a href=\"#fn34-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 34\">34</a></sup>fêmea<a name=\"rf35-8629\"></a><sup><a href=\"#fn35-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 35\">35</a></sup>pare ela<a name=\"rf36-8629\"></a><sup><a href=\"#fn36-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 36\">36</a></sup>.</p>"
        },
        {
          "line_index": 1,
          "text": "E está ela impurasétuplos.",
          "raw_html": "<p class=\"wp-block-paragraph\">E está ela impura<a name=\"rf37-8629\"></a><sup><a href=\"#fn37-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 37\">37</a></sup>sétuplos<a name=\"rf38-8629\"></a><sup><a href=\"#fn38-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 38\">38</a></sup>.</p>"
        },
        {
          "line_index": 2,
          "text": "Conforme a menstruaçãodela.",
          "raw_html": "<p class=\"wp-block-paragraph\">Conforme a menstruação<a name=\"rf39-8629\"></a><sup><a href=\"#fn39-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 39\">39</a></sup>dela.</p>"
        },
        {
          "line_index": 3,
          "text": "E sessentadiae seis de diasassentaela sobre os sanguesda purificação.",
          "raw_html": "<p class=\"wp-block-paragraph\">E sessenta<a name=\"rf40-8629\"></a><sup><a href=\"#fn40-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 40\">40</a></sup>dia<a name=\"rf41-8629\"></a><sup><a href=\"#fn41-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 41\">41</a></sup>e seis de dias<a name=\"rf42-8629\"></a><sup><a href=\"#fn42-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 42\">42</a></sup>assenta<a name=\"rf43-8629\"></a><sup><a href=\"#fn43-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 43\">43</a></sup>ela sobre os sangues<a name=\"rf44-8629\"></a><sup><a href=\"#fn44-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 44\">44</a></sup>da purificação<a name=\"rf45-8629\"></a><sup><a href=\"#fn45-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 45\">45</a></sup>.</p>"
        }
      ]
    },
    {
      "number": 6,
      "text": "E no encherdos dias da purificação dela. Para filho. Oupara filha. Faz ela ircordeiro. O filhodo anodele. Para subimento. E filhode pomba. Ou rola. Para pecado. À abertura da tenda de período. Ao sacerdote.",
      "lines": [
        {
          "line_index": 0,
          "text": "E no encherdos dias da purificação dela.",
          "raw_html": "<p class=\"wp-block-paragraph\"> E no encher<a name=\"rf46-8629\"></a><sup><a href=\"#fn46-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 46\">46</a></sup>dos dias da purificação dela<a name=\"rf47-8629\"></a><sup><a href=\"#fn47-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 47\">47</a></sup>.</p>"
        },
        {
          "line_index": 1,
          "text": "Para filho.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para filho<a name=\"rf48-8629\"></a><sup><a href=\"#fn48-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 48\">48</a></sup>.</p>"
        },
        {
          "line_index": 2,
          "text": "Oupara filha.",
          "raw_html": "<p class=\"wp-block-paragraph\">Ou<a name=\"rf49-8629\"></a><sup><a href=\"#fn49-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 49\">49</a></sup>para filha<a name=\"rf50-8629\"></a><sup><a href=\"#fn50-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 50\">50</a></sup>.</p>"
        },
        {
          "line_index": 3,
          "text": "Faz ela ircordeiro.",
          "raw_html": "<p class=\"wp-block-paragraph\">Faz ela ir<a name=\"rf51-8629\"></a><sup><a href=\"#fn51-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 51\">51</a></sup>cordeiro<a name=\"rf52-8629\"></a><sup><a href=\"#fn52-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 52\">52</a></sup>.</p>"
        },
        {
          "line_index": 4,
          "text": "O filhodo anodele.",
          "raw_html": "<p class=\"wp-block-paragraph\">O filho<a name=\"rf53-8629\"></a><sup><a href=\"#fn53-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 53\">53</a></sup>do ano<a name=\"rf54-8629\"></a><sup><a href=\"#fn54-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 54\">54</a></sup>dele<a name=\"rf55-8629\"></a><sup><a href=\"#fn55-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 55\">55</a></sup><a name=\"rf56-8629\"></a><sup><a href=\"#fn56-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 56\">56</a></sup>.</p>"
        },
        {
          "line_index": 5,
          "text": "Para subimento.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para subimento<a name=\"rf57-8629\"></a><sup><a href=\"#fn57-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 57\">57</a></sup>.</p>"
        },
        {
          "line_index": 6,
          "text": "E filhode pomba.",
          "raw_html": "<p class=\"wp-block-paragraph\">E filho<a name=\"rf58-8629\"></a><sup><a href=\"#fn58-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 58\">58</a></sup>de pomba<a name=\"rf59-8629\"></a><sup><a href=\"#fn59-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 59\">59</a></sup>.</p>"
        },
        {
          "line_index": 7,
          "text": "Ou rola.",
          "raw_html": "<p class=\"wp-block-paragraph\">Ou rola<a name=\"rf60-8629\"></a><sup><a href=\"#fn60-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 60\">60</a></sup>.</p>"
        },
        {
          "line_index": 8,
          "text": "Para pecado.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para pecado<a name=\"rf61-8629\"></a><sup><a href=\"#fn61-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 61\">61</a></sup>.</p>"
        },
        {
          "line_index": 9,
          "text": "À abertura da tenda de período.",
          "raw_html": "<p class=\"wp-block-paragraph\">À abertura da tenda de período<a name=\"rf62-8629\"></a><sup><a href=\"#fn62-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 62\">62</a></sup>.</p>"
        },
        {
          "line_index": 10,
          "text": "Ao sacerdote.",
          "raw_html": "<p class=\"wp-block-paragraph\">Ao sacerdote<a name=\"rf63-8629\"></a><sup><a href=\"#fn63-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 63\">63</a></sup>.</p>"
        }
      ]
    },
    {
      "number": 7,
      "text": "E faz ele aproximar ele. Para as faces de Yahweh. E encobre elesobre ela. E está ela pura. Desde o manancialdos sanguesdela. Essa e a instrução daparida. Para o macho. Ou para a fêmea.",
      "lines": [
        {
          "line_index": 0,
          "text": "E faz ele aproximar ele.",
          "raw_html": "<p class=\"wp-block-paragraph\"> E faz ele aproximar ele.</p>"
        },
        {
          "line_index": 1,
          "text": "Para as faces de Yahweh.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para as faces de Yahweh<a name=\"rf64-8629\"></a><sup><a href=\"#fn64-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 64\">64</a></sup>.</p>"
        },
        {
          "line_index": 2,
          "text": "E encobre elesobre ela.",
          "raw_html": "<p class=\"wp-block-paragraph\">E encobre ele<a name=\"rf65-8629\"></a><sup><a href=\"#fn65-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 65\">65</a></sup>sobre ela<a name=\"rf66-8629\"></a><sup><a href=\"#fn66-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 66\">66</a></sup>.</p>"
        },
        {
          "line_index": 3,
          "text": "E está ela pura.",
          "raw_html": "<p class=\"wp-block-paragraph\">E está ela pura<a name=\"rf67-8629\"></a><sup><a href=\"#fn67-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 67\">67</a></sup>.</p>"
        },
        {
          "line_index": 4,
          "text": "Desde o manancialdos sanguesdela.",
          "raw_html": "<p class=\"wp-block-paragraph\">Desde o manancial<a name=\"rf68-8629\"></a><sup><a href=\"#fn68-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 68\">68</a></sup>dos sangues<a name=\"rf69-8629\"></a><sup><a href=\"#fn69-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 69\">69</a></sup>dela.</p>"
        },
        {
          "line_index": 5,
          "text": "Essa e a instrução daparida.",
          "raw_html": "<p class=\"wp-block-paragraph\">Essa e a instrução da<a name=\"rf70-8629\"></a><sup><a href=\"#fn70-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 70\">70</a></sup>parida<a name=\"rf71-8629\"></a><sup><a href=\"#fn71-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 71\">71</a></sup>.</p>"
        },
        {
          "line_index": 6,
          "text": "Para o macho.",
          "raw_html": "<p class=\"wp-block-paragraph\">Para o macho<a name=\"rf72-8629\"></a><sup><a href=\"#fn72-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 72\">72</a></sup>.</p>"
        },
        {
          "line_index": 7,
          "text": "Ou para a fêmea.",
          "raw_html": "<p class=\"wp-block-paragraph\">Ou para a fêmea<a name=\"rf73-8629\"></a><sup><a href=\"#fn73-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 73\">73</a></sup>.</p>"
        }
      ]
    },
    {
      "number": 8,
      "text": "E se não encontra a mão dela suficiência de miunça. E toma eladuas de rolas. Ou dois de filhos de pomba. Umpara subimento. E umpara pecado. E faz encobrir sobre elao sacerdote. E está ela pura.",
      "lines": [
        {
          "line_index": 0,
          "text": "E se não encontra a mão dela suficiência de miunça.",
          "raw_html": "<p class=\"wp-block-paragraph\"> E se não<a name=\"rf74-8629\"></a><sup><a href=\"#fn74-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 74\">74</a></sup> encontra<a name=\"rf75-8629\"></a><sup><a href=\"#fn75-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 75\">75</a></sup> a mão dela<a name=\"rf76-8629\"></a><sup><a href=\"#fn76-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 76\">76</a></sup> suficiência de miunça<a name=\"rf77-8629\"></a><sup><a href=\"#fn77-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 77\">77</a></sup>.</p>"
        },
        {
          "line_index": 1,
          "text": "E toma eladuas de rolas.",
          "raw_html": "<p class=\"wp-block-paragraph\">E toma ela<a name=\"rf78-8629\"></a><sup><a href=\"#fn78-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 78\">78</a></sup>duas de rolas<a name=\"rf79-8629\"></a><sup><a href=\"#fn79-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 79\">79</a></sup>.</p>"
        },
        {
          "line_index": 2,
          "text": "Ou dois de filhos de pomba.",
          "raw_html": "<p class=\"wp-block-paragraph\">Ou<a name=\"rf80-8629\"></a><sup><a href=\"#fn80-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 80\">80</a></sup> dois de<a name=\"rf81-8629\"></a><sup><a href=\"#fn81-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 81\">81</a></sup> filhos de pomba<a name=\"rf82-8629\"></a><sup><a href=\"#fn82-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 82\">82</a></sup>.</p>"
        },
        {
          "line_index": 3,
          "text": "Umpara subimento.",
          "raw_html": "<p class=\"wp-block-paragraph\">Um<a name=\"rf83-8629\"></a><sup><a href=\"#fn83-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 83\">83</a></sup>para subimento<a name=\"rf84-8629\"></a><sup><a href=\"#fn84-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 84\">84</a></sup><a name=\"rf85-8629\"></a><sup><a href=\"#fn85-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 85\">85</a></sup>.</p>"
        },
        {
          "line_index": 4,
          "text": "E umpara pecado.",
          "raw_html": "<p class=\"wp-block-paragraph\">E um<a name=\"rf86-8629\"></a><sup><a href=\"#fn86-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 86\">86</a></sup>para pecado<a name=\"rf87-8629\"></a><sup><a href=\"#fn87-8629\" rel=\"footnote\" title=\"Clique para ir para a nota de rodapé 87\">87</a></sup>.</p>"
